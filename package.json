{
	"name": "@w-lfpup/coyote",
	"version": "0.1.1",
	"description": "html templates",
	"type": "module",
	"main": "dist/mod.js",
	"scripts": {
		"prepare": "npm run build",
		"build": "npm run build:dev && npm run build:tests",
		"build:dev": "npx tsc --project src/tsconfig.json",
		"build:tests": "npx tsc --project tests/tsconfig.json",
		"format": "npx prettier --write ./",
		"test": "npm run test:nodejs && npm run test:browsers",
		"test:nodejs": "npx jackrabbit ./tests/dist/mod.js",
		"test:browsers": "npx jackrabbit_webdriver jr.json tests/dist/mod.js"
	},
	"author": "wolfpup",
	"license": "BSD-3-Clause",
	"devDependencies": {
		"@w-lfpup/jackrabbit": "^0.3.3",
		"prettier": "^3.8.4",
		"typescript": "^6.0.3"
	}
}
